# LLM (OpenRouter — OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1
OPENROUTER_REFERER=http://localhost:3000

# Database (Postgres on Railway)
DATABASE_URL=

# Storage (Cloudflare R2 — optional in Phase 1; falls back to ./uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=hirex-recordings
R2_PUBLIC_BASE_URL=

# Auth (Clerk — optional in Phase 1; falls back to single-user dev mode)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# JWT for candidate links
JWT_SIGNING_SECRET=change-me-in-production-please

# Queue (optional in Phase 1; falls back to in-process)
REDIS_URL=

# Observability (optional)
SENTRY_DSN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:5050
NODE_ENV=development
PORT=5050
